# LAMMPS input script for Alanine Dipeptide MD simulation
# Date: October 2025

# Initialize simulation
units           real
dimension       3
boundary        p p p
atom_style      full

# Read data file
read_data       ala2.data

# Define force field parameters
pair_style      lj/cut/coul/long 12.0
pair_coeff      1 1 0.086 3.40  # C-C
pair_coeff      2 2 0.170 3.25  # N-N  
pair_coeff      3 3 0.210 2.96  # O-O
pair_coeff      4 4 0.030 2.50  # H-H
pair_modify     mix geometric

# Bond parameters
bond_style      harmonic
bond_coeff      1 340.0 1.09   # Generic bond

# Angle parameters  
angle_style     harmonic
angle_coeff     1 50.0 109.5   # Generic angle

# Dihedral parameters
dihedral_style  harmonic
dihedral_coeff  1 180.0 1 1  # Generic dihedral



# Coulombic interactions
kspace_style    pppm 1.0e-4

# Neighbor settings
neighbor        2.0 bin
neigh_modify    delay 0 every 20 check no

# Thermostat and barostat
fix             1 all nvt temp 300.0 300.0 100.0
fix             2 all shake 1.0e-4 20 0 b 1

# Output settings
thermo          1000
thermo_style    custom step temp press pe ke etotal vol density

# Trajectory output
dump            1 all xyz 1000 trajectory.xyz
dump_modify     1 element C N O H

# Restart files
restart         10000 restart.*.lmp

# Energy minimization
minimize        1.0e-4 1.0e-6 1000 10000

# Equilibration
reset_timestep  0
timestep        1.0
run             100000

# Production run
; write_restart   equilibrated.restart
; run             1000000

print           "Simulation completed successfully!"